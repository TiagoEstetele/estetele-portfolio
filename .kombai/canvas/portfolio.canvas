      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n\n@keyframes floatA {\n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-10px); }\n}\n@keyframes floatB {\n  0%, 100% { transform: translateY(0px) translateX(0px); }\n  40% { transform: translateY(-7px) translateX(4px); }\n  80% { transform: translateY(5px) translateX(-3px); }\n}\n@keyframes floatC {\n  0%, 100% { transform: translateY(0px); }\n  60% { transform: translateY(-12px); }\n}\n@keyframes pulseGlow {\n  0%, 100% { opacity: 0.5; }\n  50% { opacity: 0.9; }\n}\n@keyframes langFade {\n  from { opacity: 0; transform: translateY(4px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n.badge-a { animation: floatA 7s ease-in-out infinite; }\n.badge-b { animation: floatB 9s ease-in-out infinite 1.5s; }\n.badge-c { animation: floatC 8s ease-in-out infinite 3s; }\n\n.tech-card {\n  transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;\n}\n.tech-card:hover {\n  border-color: rgba(255,255,255,0.14) !important;\n  background: rgba(255,255,255,0.042) !important;\n  box-shadow: 0 0 40px rgba(112,0,255,0.07), 0 12px 48px rgba(0,0,0,0.5) !important;\n  transform: translateY(-2px);\n}\n\n.cta-primary {\n  transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;\n}\n.cta-primary:hover {\n  background: #ffffff !important;\n  box-shadow: 0 0 32px rgba(255,255,255,0.18) !important;\n  transform: translateY(-2px);\n}\n.cta-secondary {\n  transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;\n}\n.cta-secondary:hover {\n  border-color: rgba(237,237,237,0.4) !important;\n  background: rgba(255,255,255,0.06) !important;\n  transform: translateY(-2px);\n}\n\n.contact-item {\n  transition: background 0.25s ease;\n  border-radius: 18px;\n}\n.contact-item:hover {\n  background: rgba(255,255,255,0.04) !important;\n}\n.contact-item:hover .c-icon,\n.contact-item:hover .c-label {\n  opacity: 1 !important;\n}\n.c-icon, .c-label {\n  transition: opacity 0.25s ease;\n}\n\n.dot-status {\n  animation: pulseGlow 2.5s ease-in-out infinite;\n}\n\n/* Language switcher */\n.lang-switcher {\n  position: absolute;\n  top: 32px;\n  right: 80px;\n  z-index: 10;\n  display: flex;\n  align-items: center;\n  gap: 2px;\n  padding: 5px;\n  background: rgba(255,255,255,0.04);\n  border: 1px solid rgba(255,255,255,0.09);\n  border-radius: 100px;\n  backdrop-filter: blur(16px);\n}\n.lang-btn {\n  padding: 6px 14px;\n  border: none;\n  border-radius: 100px;\n  font-size: 12px;\n  font-weight: 600;\n  letter-spacing: 0.06em;\n  cursor: pointer;\n  font-family: 'Inter', sans-serif;\n  transition: background 0.2s ease, color 0.2s ease;\n  background: transparent;\n  color: rgba(237,237,237,0.38);\n}\n.lang-btn.active {\n  background: rgba(255,255,255,0.1);\n  color: rgba(237,237,237,0.9);\n  box-shadow: 0 1px 4px rgba(0,0,0,0.3);\n}\n.lang-btn:hover:not(.active) {\n  color: rgba(237,237,237,0.65);\n}\n\n[data-i18n] {\n  animation: langFade 0.25s ease forwards;\n}\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n\n<div id=\"portfolio-root\" style=\"font-family:'Inter',sans-serif;background:#0a0a0a;color:#ededed;overflow-x:hidden;\" data-kid=\"2\">\n\n  \n  <section style=\"position:relative;min-height:940px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120px 80px;overflow:hidden;\" data-kid=\"3\">\n\n    \n    <div class=\"lang-switcher\" data-kid=\"4\">\n      <button class=\"lang-btn active\" id=\"btn-en\" onclick=\"setLang('en')\" data-kid=\"5\">EN</button>\n      <button class=\"lang-btn\" id=\"btn-pt\" onclick=\"setLang('pt')\" data-kid=\"6\">PT</button>\n    </div>\n\n    \n    <div style=\"position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.055) 1px,transparent 1px);background-size:30px 30px;pointer-events:none;\" data-kid=\"7\"></div>\n    \n    <div style=\"position:absolute;top:42%;left:50%;transform:translate(-50%,-50%);width:1100px;height:560px;background:radial-gradient(ellipse at center,rgba(112,0,255,0.14) 0%,rgba(255,92,0,0.07) 45%,transparent 70%);filter:blur(50px);pointer-events:none;\" data-kid=\"8\"></div>\n    \n    <div style=\"position:absolute;top:-120px;left:-80px;width:520px;height:520px;background:radial-gradient(ellipse,rgba(112,0,255,0.09) 0%,transparent 70%);filter:blur(70px);pointer-events:none;\" data-kid=\"9\"></div>\n    \n    <div style=\"position:absolute;bottom:-60px;right:-60px;width:440px;height:440px;background:radial-gradient(ellipse,rgba(255,92,0,0.08) 0%,transparent 70%);filter:blur(70px);pointer-events:none;\" data-kid=\"10\"></div>\n\n    \n    <div class=\"badge-a\" style=\"position:absolute;top:172px;left:160px;display:flex;align-items:center;gap:9px;padding:11px 20px;background:rgba(255,255,255,0.045);border:1px solid rgba(255,255,255,0.1);border-radius:100px;backdrop-filter:blur(16px);font-size:13px;color:rgba(237,237,237,0.72);font-weight:500;white-space:nowrap;box-shadow:0 4px 20px rgba(0,0,0,0.3);\" data-kid=\"11\">\n      <i class=\"ti ti-wifi\" style=\"font-size:14px;color:rgba(255,255,255,0.45);\" data-kid=\"12\"></i>\n      <span data-i18n=\"badge_remote\" data-kid=\"13\">Remote since 2022</span>\n    </div>\n    \n    <div class=\"badge-b\" style=\"position:absolute;top:390px;right:140px;display:flex;align-items:center;gap:9px;padding:11px 20px;background:rgba(255,255,255,0.045);border:1px solid rgba(255,255,255,0.1);border-radius:100px;backdrop-filter:blur(16px);font-size:13px;color:rgba(237,237,237,0.72);font-weight:500;white-space:nowrap;box-shadow:0 4px 20px rgba(0,0,0,0.3);\" data-kid=\"14\">\n      <i class=\"ti ti-map-pin\" style=\"font-size:14px;color:rgba(255,255,255,0.45);\" data-kid=\"15\"></i>\n      <span data-i18n=\"badge_location\" data-kid=\"16\">Based in Brazil</span>\n    </div>\n    \n    <div class=\"badge-c\" style=\"position:absolute;bottom:220px;left:130px;display:flex;align-items:center;gap:9px;padding:11px 20px;background:rgba(112,0,255,0.1);border:1px solid rgba(112,0,255,0.25);border-radius:100px;backdrop-filter:blur(16px);font-size:13px;color:rgba(195,150,255,0.85);font-weight:500;white-space:nowrap;box-shadow:0 4px 24px rgba(112,0,255,0.12);\" data-kid=\"17\">\n      <i class=\"ti ti-cpu\" style=\"font-size:14px;color:rgba(160,100,255,0.7);\" data-kid=\"18\"></i>\n      <span data-i18n=\"badge_ai\" data-kid=\"19\">AI Enthusiast</span>\n    </div>\n\n    \n    <div style=\"position:relative;z-index:1;max-width:880px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:28px;\" data-kid=\"20\">\n      \n      <div style=\"display:inline-flex;align-items:center;gap:10px;padding:7px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:12px;color:rgba(237,237,237,0.45);letter-spacing:0.09em;text-transform:uppercase;font-weight:600;\" data-kid=\"21\">\n        <span class=\"dot-status\" style=\"width:6px;height:6px;background:#7000FF;border-radius:50%;display:inline-block;box-shadow:0 0 10px rgba(112,0,255,0.9);\" data-kid=\"22\"></span>\n        <span data-i18n=\"eyebrow\" data-kid=\"23\">Front-End Developer</span>\n      </div>\n      \n      <h1 style=\"font-size:76px;font-weight:800;line-height:1.04;letter-spacing:-0.042em;margin:0;background:linear-gradient(150deg,#ffffff 0%,rgba(237,237,237,0.88) 40%,rgba(190,190,190,0.65) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;\" data-kid=\"24\">\n        <span data-i18n=\"hero_headline\" data-kid=\"25\">Building scalable web experiences and exploring the future of AI.</span>\n      </h1>\n      \n      <p style=\"font-size:18px;line-height:1.72;color:rgba(237,237,237,0.5);max-width:580px;margin:0;font-weight:400;letter-spacing:-0.005em;\" data-i18n=\"hero_sub\" data-kid=\"26\">\n        Specialized in <span style=\"color:rgba(237,237,237,0.85);font-weight:500;\" data-kid=\"27\">React, Next.js, TypeScript, WordPress</span> and <span style=\"color:rgba(237,237,237,0.85);font-weight:500;\" data-kid=\"28\">Strapi</span>. Currently expanding into Software Architecture, Back-end Development, and AI Engineering.\n      </p>\n      \n      <div style=\"display:flex;gap:14px;align-items:center;margin-top:8px;\" data-kid=\"29\">\n        <button class=\"cta-primary\" style=\"display:inline-flex;align-items:center;gap:9px;padding:15px 30px;background:#ededed;color:#0a0a0a;border:none;border-radius:100px;font-size:15px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.015em;\" data-kid=\"30\">\n          <i class=\"ti ti-send-2\" style=\"font-size:15px;\" data-kid=\"31\"></i>\n          <span data-i18n=\"cta_contact\" data-kid=\"32\">Get in Touch</span>\n        </button>\n        <button class=\"cta-secondary\" style=\"display:inline-flex;align-items:center;gap:9px;padding:15px 30px;background:transparent;color:rgba(237,237,237,0.85);border:1px solid rgba(237,237,237,0.18);border-radius:100px;font-size:15px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.015em;\" data-kid=\"33\">\n          <span data-i18n=\"cta_stack\" data-kid=\"34\">Explore My Stack</span>\n          <i class=\"ti ti-arrow-down\" style=\"font-size:14px;color:rgba(237,237,237,0.4);\" data-kid=\"35\"></i>\n        </button>\n      </div>\n    </div>\n\n    \n    <div style=\"position:absolute;bottom:0;left:0;right:0;height:120px;background:linear-gradient(to bottom,transparent,#0a0a0a);pointer-events:none;\" data-kid=\"36\"></div>\n  </section>\n\n\n  \n  <section style=\"padding:120px 80px;max-width:1440px;margin:0 auto;box-sizing:border-box;\" data-kid=\"37\">\n    <div style=\"text-align:center;margin-bottom:72px;\" data-kid=\"38\">\n      <div style=\"display:inline-flex;align-items:center;gap:8px;padding:7px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:12px;color:rgba(237,237,237,0.38);letter-spacing:0.09em;text-transform:uppercase;font-weight:600;margin-bottom:24px;\" data-kid=\"39\">\n        <span data-i18n=\"tech_pill\" data-kid=\"40\">My Stack</span>\n      </div>\n      <h2 style=\"font-size:50px;font-weight:700;letter-spacing:-0.035em;margin:0 0 14px 0;color:#ededed;line-height:1.1;\" data-i18n=\"tech_heading\" data-kid=\"41\">The tools I build with</h2>\n      <p style=\"font-size:16px;color:rgba(237,237,237,0.38);max-width:460px;margin:0 auto;line-height:1.65;\" data-i18n=\"tech_sub\" data-kid=\"42\">Carefully chosen technologies for modern, scalable, and performant web applications.</p>\n    </div>\n\n    \n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:14px;\" data-kid=\"43\">\n\n      \n      <div class=\"tech-card\" style=\"grid-column:span 2;padding:38px;background:rgba(255,255,255,0.022);border:1px solid rgba(255,255,255,0.07);border-radius:24px;position:relative;overflow:hidden;\" data-kid=\"44\">\n        <div style=\"position:absolute;top:-50px;right:-50px;width:260px;height:260px;background:radial-gradient(ellipse,rgba(112,0,255,0.1) 0%,transparent 70%);filter:blur(30px);pointer-events:none;\" data-kid=\"45\"></div>\n        <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:26px;\" data-kid=\"46\">\n          <div style=\"width:42px;height:42px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"47\">\n            <i class=\"ti ti-layout-2\" style=\"font-size:18px;color:rgba(255,255,255,0.65);\" data-kid=\"48\"></i>\n          </div>\n          <div data-kid=\"49\">\n            <h3 style=\"font-size:16px;font-weight:600;margin:0;color:#ededed;letter-spacing:-0.02em;\" data-i18n=\"cat_frontend\" data-kid=\"50\">Frontend</h3>\n            <p style=\"font-size:13px;color:rgba(237,237,237,0.32);margin:3px 0 0;font-weight:400;\" data-i18n=\"cat_frontend_sub\" data-kid=\"51\">UI & Experience</p>\n          </div>\n        </div>\n        <div style=\"display:flex;flex-wrap:wrap;gap:8px;\" data-kid=\"52\">\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"53\">React</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"54\">Next.js</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"55\">TypeScript</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"56\">JavaScript</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"57\">HTML5</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"58\">CSS3</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"59\">Tailwind CSS</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"60\">Styled Components</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"61\">Framer Motion</span>\n        </div>\n      </div>\n\n      \n      <div class=\"tech-card\" style=\"padding:38px;background:rgba(255,255,255,0.022);border:1px solid rgba(255,255,255,0.07);border-radius:24px;position:relative;overflow:hidden;\" data-kid=\"62\">\n        <div style=\"position:absolute;top:-30px;right:-30px;width:180px;height:180px;background:radial-gradient(ellipse,rgba(255,92,0,0.09) 0%,transparent 70%);filter:blur(24px);pointer-events:none;\" data-kid=\"63\"></div>\n        <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:26px;\" data-kid=\"64\">\n          <div style=\"width:42px;height:42px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"65\">\n            <i class=\"ti ti-server\" style=\"font-size:18px;color:rgba(255,255,255,0.65);\" data-kid=\"66\"></i>\n          </div>\n          <div data-kid=\"67\">\n            <h3 style=\"font-size:16px;font-weight:600;margin:0;color:#ededed;letter-spacing:-0.02em;\" data-i18n=\"cat_backend\" data-kid=\"68\">Backend</h3>\n            <p style=\"font-size:13px;color:rgba(237,237,237,0.32);margin:3px 0 0;font-weight:400;\" data-i18n=\"cat_backend_sub\" data-kid=\"69\">APIs & Services</p>\n          </div>\n        </div>\n        <div style=\"display:flex;flex-wrap:wrap;gap:8px;\" data-kid=\"70\">\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"71\">Node.js</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"72\">Express</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"73\">REST APIs</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"74\">GraphQL</span>\n        </div>\n      </div>\n\n      \n      <div class=\"tech-card\" style=\"padding:38px;background:rgba(255,255,255,0.022);border:1px solid rgba(255,255,255,0.07);border-radius:24px;position:relative;overflow:hidden;\" data-kid=\"75\">\n        <div style=\"position:absolute;bottom:-20px;left:-20px;width:160px;height:160px;background:radial-gradient(ellipse,rgba(112,0,255,0.08) 0%,transparent 70%);filter:blur(24px);pointer-events:none;\" data-kid=\"76\"></div>\n        <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:26px;\" data-kid=\"77\">\n          <div style=\"width:42px;height:42px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"78\">\n            <i class=\"ti ti-database\" style=\"font-size:18px;color:rgba(255,255,255,0.65);\" data-kid=\"79\"></i>\n          </div>\n          <div data-kid=\"80\">\n            <h3 style=\"font-size:16px;font-weight:600;margin:0;color:#ededed;letter-spacing:-0.02em;\" data-kid=\"81\">CMS</h3>\n            <p style=\"font-size:13px;color:rgba(237,237,237,0.32);margin:3px 0 0;font-weight:400;\" data-i18n=\"cat_cms_sub\" data-kid=\"82\">Content Management</p>\n          </div>\n        </div>\n        <div style=\"display:flex;flex-wrap:wrap;gap:8px;\" data-kid=\"83\">\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"84\">WordPress</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"85\">Strapi</span>\n          <span style=\"padding:6px 15px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:100px;font-size:13px;color:rgba(237,237,237,0.68);font-weight:500;\" data-kid=\"86\">Contentful</span>\n        </div>\n      </div>\n\n      \n      <div class=\"tech-card\" style=\"padding:38px;background:rgba(255,255,255,0.022);border:1px solid rgba(255,255,255,0.07);border-radius:24px;position:relative;overflow:hidden;\" data-kid=\"87\">\n        <div style=\"position:absolute;top:-30px;right:-30px;width:160px;height:160px;background:radial-gradient(ellipse,rgba(0,200,120,0.07) 0%,transparent 70%);filter:blur(24px);pointer-events:none;\" data-kid=\"88\"></div>\n        <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:26px;\" data-kid=\"89\">\n          <div style=\"width:42px;height:42px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"90\">\n            <i class=\"ti ti-database-search\" style=\"font-size:18px;color:rgba(255,255,255,0.65);\" data-kid=\"91\"></i>\n          </div>\n          <div data-kid=\"92\">\n            <h3 style=\"font-size:16px;font-weight:600;margin:0;color:#ededed;letter-spacing:-0.02em;\" data-i18n=\"cat_database\" data-kid=\"93\">Database</h3>\n            <p style=\"font-size:13px;colo